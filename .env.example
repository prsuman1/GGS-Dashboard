# Copy this file to `.env` (in this folder or the parent folder) and fill in values.
# `.env` is gitignored — never commit real credentials.

# Redshift (read-only) connection — used only by snapshot.py
REDSHIFT_DB=prod2-generico
REDSHIFT_HOST=your-redshift-host
REDSHIFT_USER=your-readonly-user
REDSHIFT_PASSWORD=your-password
REDSHIFT_PORT=5439

# Dashboard login (add more users by incrementing the index)
DASH_USER1=Manish
DASH_PASS1=changeme
DASH_USER2=Harshit
DASH_PASS2=changeme
